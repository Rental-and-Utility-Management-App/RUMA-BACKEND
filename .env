# Môi trường chạy: development | production
# Khi APP_ENV=production, app sẽ BẮT BUỘC phải có JWT_SECRET hợp lệ (>= 32 ký tự,
# không được để mặc định) nếu không sẽ crash ngay khi khởi động.
APP_ENV=development

# Cổng server lắng nghe
PORT=8080

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=rental_app

# JWT
# Production: bắt buộc set chuỗi ngẫu nhiên tối thiểu 32 ký tự, ví dụ tạo bằng:
#   openssl rand -base64 48
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_HOURS=72

# CORS - danh sách domain frontend được phép gọi API, phân cách bằng dấu phẩy.
# Dùng "*" để cho phép tất cả (chỉ nên dùng khi dev, KHÔNG dùng ở production).
# Ví dụ production: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*
