                        "name": "room_id",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Lọc theo trạng thái",
                        "name": "status",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
