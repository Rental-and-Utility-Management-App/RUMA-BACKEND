    "definitions": {
        "handlers.changePasswordRequest": {
            "type": "object",
            "required": [
                "new_password",
                "old_password"
            ],
            "properties": {
                "new_password": {
                    "type": "string",
                    "minLength": 6
                },
                "old_password": {
                    "type": "string"
                }
            }
        },
        "handlers.createInvoiceRequest": {
            "type": "object",
            "required": [
                "electric_new",
                "month",
                "room_id",
                "water_new",
                "year"
            ],
            "properties": {
                "due_date": {
                    "description": "format: 2006-01-02",
                    "type": "string"
                },
                "electric_new": {
                    "type": "number"
                },
                "electric_old": {
                    "description": "ElectricOld/WaterOld: để trống (null) để hệ thống TỰ ĐỘNG lấy chỉ số mới nhất\n(electric_new/water_new) của hóa đơn gần nhất cùng phòng làm chỉ số cũ tháng này.\nChỉ cần nhập tay khi: hóa đơn đầu tiên của phòng, hoặc vừa thay đồng hồ điện/nước mới.",
                    "type": "number"
                },
                "month": {
                    "type": "integer",
                    "maximum": 12,
                    "minimum": 1
                },
                "other_fees": {
                    "type": "number"
                },
                "other_note": {
                    "type": "string"
                },
                "room_id": {
                    "type": "string"
                },
                "water_new": {
                    "type": "number"
                },
                "water_old": {
                    "type": "number"
                },
                "year": {
                    "type": "integer"
                }
            }
        },
        "handlers.createPaymentRequest": {
            "type": "object",
            "required": [
                "amount",
                "invoice_id",
                "method"
            ],
            "properties": {
                "amount": {
                    "type": "number"
                },
                "invoice_id": {
                    "type": "string"
                },
                "method": {
                    "description": "cash | bank_transfer | other",
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "paid_at": {
                    "description": "format: 2006-01-02, mặc định là hôm nay",
                    "type": "string"
                }
            }
        },
        "handlers.createRoomRequest": {
            "type": "object",
            "required": [
                "code",
                "electric_price",
                "monthly_rent",
                "water_price"
            ],
            "properties": {
                "code": {
                    "type": "string"
                },
                "electric_price": {
                    "type": "number"
                },
                "floor": {
                    "type": "integer"
                },
                "monthly_rent": {
                    "type": "number"
                },
                "name": {
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "water_price": {
                    "type": "number"
                }
            }
        },
        "handlers.createTenantRequest": {
            "type": "object",
            "required": [
                "full_name",
                "password",
                "phone"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "full_name": {
                    "type": "string"
                },
                "password": {
                    "type": "string",
                    "minLength": 6
                },
                "phone": {
                    "type": "string"
                },
                "room_id": {
                    "description": "optional lúc tạo, có thể gán phòng sau",
                    "type": "string"
                }
            }
        },
        "handlers.loginRequest": {
            "type": "object",
            "required": [
                "password",
                "phone"
            ],
            "properties": {
                "password": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                }
            }
        },
        "handlers.updateRoomRequest": {
            "type": "object",
            "properties": {
                "electric_price": {
                    "type": "number"
                },
                "floor": {
                    "type": "integer"
                },
                "monthly_rent": {
                    "type": "number"
                },
                "name": {
                    "type": "string"
                },
                "note": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                },
                "water_price": {
                    "type": "number"
                }
            }
        },
        "handlers.updateTenantRequest": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                },
                "full_name": {
                    "type": "string"
                },
                "is_active": {
                    "type": "boolean"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Nhập theo định dạng: Bearer {token}",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}